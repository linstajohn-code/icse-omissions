# ─────────────────────────────────────────────────────────────────────────────
# ICSE Omissions — environment variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project (find at app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — only used by scripts/seed-db.ts (server-side only, never shipped to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
