{
  "name": "icse-omissions",
  "version": "0.0.0",
  "private": true,
  "description": "Public reference for ICSE Class 9 & 10 syllabus, citable to the official CISCE Regulations PDFs.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ingest:cisce": "tsx scripts/ingest-cisce.ts",
    "db:seed": "tsx --env-file=.env.local scripts/seed-db.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2",
    "@tanstack/react-query": "^5",
    "canvas": "^3.1.0",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "commander": "^12.1.0",
    "framer-motion": "^12",
    "lucide-react": "^0.460",
    "next": "15",
    "next-themes": "^0.4",
    "pdfjs-dist": "^4.9.155",
    "react": "19",
    "react-dom": "19",
    "tailwind-merge": "^2",
    "zod": "^3.23.8",
    "zustand": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15",
    "tailwindcss": "^4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
