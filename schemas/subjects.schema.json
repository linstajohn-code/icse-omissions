{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://icse-omissions.local/schemas/subjects.schema.json",
  "title": "ICSE Subjects Seed List",
  "type": "object",
  "required": ["subjects"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "name", "group", "slug"],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z]{2,6}$",
            "description": "Uppercase short code, e.g. MATH, PHY, HCG. Subject to reconciliation with the CISCE PDF in Phase 1."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "group": {
            "type": "string",
            "enum": ["I", "II", "III"],
            "description": "ICSE subject group: I = core compulsory, II = elective (pick 2), III = elective (pick 1)."
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
